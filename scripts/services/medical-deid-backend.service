[Unit]
Description=Medical De-identification Backend API
After=network.target

[Service]
Type=simple
User=eric
Group=eric
WorkingDirectory=/home/eric/workspace260113/medical-deidentification/web/backend
Environment="PATH=/home/eric/workspace260113/medical-deidentification/.venv/bin:/usr/local/bin:/usr/bin:/bin"
Environment="OLLAMA_BASE_URL=http://192.168.1.2:30133"
Environment="OLLAMA_MODEL=gemma3:27b"
ExecStart=/home/eric/workspace260113/medical-deidentification/.venv/bin/uvicorn main:app --host 0.0.0.0 --port 8000
Restart=always
RestartSec=5
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
